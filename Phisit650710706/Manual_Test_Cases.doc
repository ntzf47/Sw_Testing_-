<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        h1 { font-family: sans-serif; text-align: center; }
        table { border-collapse: collapse; width: 100%; font-family: sans-serif; font-size: 11pt; }
        th, td { border: 1px solid black; padding: 8px; text-align: left; vertical-align: top; }
        th { background-color: #f2f2f2; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Manual Test Cases - Phisit</h1>
    <table>
        <thead>
            <tr>
                <th>TC ID</th>
                <th>โมดูล / ฟังก์ชัน</th>
                <th>ประเภท</th>
                <th>คำอธิบาย</th>
                <th>ขั้นตอนการทดสอบ</th>
                <th>ผลลัพธ์ที่คาดหวัง</th>
            </tr>
        </thead>
        <tbody>
            <tr><td>TC-PEN-001</td><td>Login</td><td>Negative</td><td>ลองใส่ SQL Injection ตอนล็อกอิน</td><td>1. ไปหน้า Login<br/>2. ใส่ Username: <code>admin' OR '1'='1'</code><br/>3. ใส่รหัสอะไรก็ได้<br/>4. กดเข้า</td><td>ระบบไม่ให้เข้า และแจ้งว่าข้อมูลไม่ถูกต้อง</td></tr>
            <tr><td>TC-PEN-002</td><td>Login</td><td>Negative</td><td>เดารหัสผ่านซ้ำ ๆ (Brute force)</td><td>ยิง request ใส่รหัสผิดหลายครั้งติดกัน</td><td>ระบบควรล็อกบัญชีชั่วคราว</td></tr>
            <tr><td>TC-PEN-003</td><td>Register</td><td>Negative</td><td>ใส่ script ใน email (XSS)</td><td>ใส่ <code>&lt;script&gt;alert(1)&lt;/script&gt;@test.com</code> แล้วสมัคร</td><td>ระบบต้องไม่รับ และแจ้งว่า email ไม่ถูกต้อง</td></tr>
            <tr><td>TC-PEN-004</td><td>Register</td><td>Positive</td><td>สมัครสมาชิกปกติ</td><td>กรอกข้อมูลครบ แล้วกดยืนยัน</td><td>สมัครสำเร็จ และไปหน้า login</td></tr>
            <tr><td>TC-PEN-005</td><td>Session</td><td>Negative</td><td>ใช้ token เดิมหลัง logout</td><td>logout แล้วเอา token เดิมไปยิง request</td><td>ระบบต้องไม่ให้ใช้ และขึ้น unauthorized</td></tr>
            <tr><td>TC-PEN-006</td><td>Admin Area</td><td>Negative</td><td>ข้ามสิทธิ์เข้าหน้าจัดการแบบไม่ Login</td><td>เข้า URL <code>/admin/create-contest</code> ไปตรงๆ</td><td>หน้าต่างบังคับให้ Redirect กลับไปหน้า Login</td></tr>
            <tr><td>TC-PEN-007</td><td>Contest</td><td>Negative</td><td>ผู้สมัครธรรมดาพยายามแก้กติกา</td><td>เข้าระบบด้วยไอดีผู้ส่งผลงาน แล้วยิง API แก้กติกา</td><td>ระบบบล็อกการทำงาน (403 Forbidden)</td></tr>
            <tr><td>TC-PEN-008</td><td>User Profile</td><td>Negative</td><td>ดึงข้อมูลของทีมงานอื่น (IDOR)</td><td>ล็อกอินแอดมินกลุ่ม A แต่เปลี่ยนค่าดึงข้อมูลกลุ่ม B</td><td>ขึ้น Error ว่าไม่มีสิทธิ์เข้าถึงข้อมูลของกลุ่มอื่น</td></tr>
            <tr><td>TC-PEN-009</td><td>Contest</td><td>Negative</td><td>ใส่ code ข้ามไซต์ (XSS) ในชื่อการประกวด</td><td>ตั้งชื่อมี iframe อันตราย</td><td>ระบบแสดงแค่ข้อความตัวอักษร ไม่ดึง iframe มาแสดงผล</td></tr>
            <tr><td>TC-PEN-010</td><td>Contest</td><td>Positive</td><td>ส่งข้อมูลใบประกวดด้วยข้อมูลครบถ้วน</td><td>กรอกชื่อ กำหนดการ และรูปภาพครบ จากนั้นกดสร้าง</td><td>ขอมุลเป็นฉบับร่าง (Draft) และ ถูกบันทึกลงระบบ</td></tr>
            <tr><td>TC-PEN-011</td><td>Submit Poem</td><td>Negative</td><td>แก้รหัสอัปโหลดในนามคนอื่น (IDOR)</td><td>ล็อกอินเป็นไอดีตนเอง แต่แก้ไอดีตอนส่งงานเป็นตนอื่น</td><td>ตีกลับหรือเซพเข้าชื่อตัวเอง ไม่สามารถส่งแทนไอดีคนอื่นได้</td></tr>
            <tr><td>TC-PEN-012</td><td>Submit Poem</td><td>Negative</td><td>ส่งข้อมูลที่เยอะเกินลิมิตทำให้ค้าง</td><td>กรอกบทกลอน 100,000 ตัวอักษร แล้วกดส่งเข้าระบบ</td><td>ตอบกลับว่าขนาดเกิน (400 Bad Request Payload Too Large)</td></tr>
            <tr><td>TC-PEN-013</td><td>File Upload</td><td>Negative</td><td>อัปโหลดไฟล์หลบซ่อนไวรัส (.exe)</td><td>แนบไฟล์ .exe แล้ว submit</td><td>ปฏิเสธการบันทึก แจ้งเตือนว่าห้ามใช้ไฟล์นามสกุลแปลก</td></tr>
            <tr><td>TC-PEN-014</td><td>File Upload</td><td>Negative</td><td>ปลอมไฟล์ pdf</td><td>สร้างไฟล์ .sh แล้วเปลี่ยนนามสกุลหลอกเป็น .pdf ส่งแทน</td><td>ระบบตรวจเจอว่าไม่ใช่ pdf จึงลบทิ้ง</td></tr>
            <tr><td>TC-PEN-015</td><td>Submit Poem</td><td>Positive</td><td>อัปโหลดภาพและผลงานปกติ</td><td>ส่งร้อยกรองสั้นๆ พร้อมด้วยภาพความละเอียดขนาด 1MB</td><td>อัปโหลดขึ้นระบบได้ แล้วเปลี่ยนสถานะเป็น 'รอตรวจ'</td></tr>
            <tr><td>TC-PEN-016</td><td>Grading</td><td>Negative</td><td>ให้คะแนนผู้แต่งติดลบ</td><td>กรรมการตรวจงานแล้วกรอกคะแนน -50 ลงไปบันทึก</td><td>ขึ้นให้กรอกใหม่ ระบุว่าคะแนนต้องอยู่ระหว่าง 0-100 เท่านั้น</td></tr>
            <tr><td>TC-PEN-017</td><td>Grading</td><td>Negative</td><td>ให้คะแนนเกินลิมิต</td><td>ใส่คะแนนส่วนความสร้างสรรค์ 9999 แล้วกดSave</td><td>ระบบ return และ แจ้งเตือนว่าค่าอยู่นอกเหนือลิมิตที่ตั้งไว้</td></tr>
            <tr><td>TC-PEN-018</td><td>Grading</td><td>Negative</td><td>ยิง API แก้คะแนนที่ตัดสินไปเสร็จแล้ว</td><td>กรรมการเรียกยิงส่งคำขอ HTTP ทับคะแนนผลเก่าทิ้ง</td><td>ไม่บันทึกการแก้รอบสองเด็ดขาด หากไม่ได้อยู่ในโหมดแก้ไข</td></tr>
            <tr><td>TC-PEN-019</td><td>Grading</td><td>Positive</td><td>กรอกคะแนนถูกช่อง และพิมพ์คอมเมนต์</td><td>ลงคะแนน 80 พิมพ์ 'ดีมาก' แล้วกดยืนยัน</td><td>เซพสำเร็จ ผลรวมคะแนนถูกต้อง และเปลี่ยนเป็น 'ตรวจแล้ว'</td></tr>
            <tr><td>TC-PEN-020</td><td>Grading</td><td>Negative</td><td>แนบโค้ดแฮ็กไว้ในคอมเมนต์ (XSS)</td><td>บรรยายพร้อมใส่รูปภาพและใส่คำสั่ง tag ปลอมไปด้วย</td><td>ไม่เรนเดอร์คำสั่ง แต่ขึ้นเป็นคำบรรยายธรรมดา หรือหายไป</td></tr>
            <tr><td>TC-PEN-021</td><td>Result</td><td>Negative</td><td>ดึงข้อมูลผู้ชนะก่อนวันจริง (IDOR)</td><td>ใส่เดา URL แบบตรงๆ ขอรับข้อมูลการประกวดที่ยังปิดอยู่</td><td>ขึ้นหน้าจอสีขาว หรือแสดงแจ้งเตือน Unauthorized</td></tr>
            <tr><td>TC-PEN-022</td><td>Result</td><td>Positive</td><td>ประกาศอย่างเป็นทางการหน้าเว็บ</td><td>กด publish</td><td>สถานะเปลี่ยนเป็นประกาศแล้ว</td></tr>
            <tr><td>TC-PEN-023</td><td>Judge Area</td><td>Negative</td><td>เพิ่มอีเมลกรรมการผสม SQL</td><td>กรอก Email ลักษณะ <code>admin'@test.com' OR 1=1;</code></td><td>ระบบไม่เพิ่มข้อมูลลง database</td></tr>
            <tr><td>TC-PEN-024</td><td>Judge Area</td><td>Positive</td><td>แอดกรรมการที่อีเมลใช้งานได้จริง</td><td>ใส่ email ถูกต้อง</td><td>เพิ่มสำเร็จ</td></tr>
            <tr><td>TC-PEN-025</td><td>Headers</td><td>Negative</td><td>ตรวจสอบ Headers ด้านปลอดภัยของเว็บ</td><td>ใช้ tools ยิงแล้วเปิดหา Headers ซ่อน CORS, HSTS</td><td>ควรมี security header</td></tr>
            <tr><td>TC-PEN-026</td><td>Path Request</td><td>Negative</td><td>ขอดูไฟล์รหัสผ่านของเซิร์ฟเวอร์</td><td>ดึงรูป แต่เปลี่ยน Path <code>/uploads/../../../etc/passwd</code></td><td>โดนบล็อกไม่ให้เข้าถึงเด็ดขาด</td></tr>
            <tr><td>TC-PEN-027</td><td>API Limit</td><td>Negative</td><td>ยิง request รัวๆ (Rate Limiting)</td><td>เขียนสคริปต์ยิงหน้าแรกไปรัวๆ 5000 ครั้งใน 10 วินาที</td><td>โดนจับอัตราการใช้งาน แล้วส่ง Error แจ้งเตือน Request เด้ง</td></tr>
            <tr><td>TC-PEN-028</td><td>Access Right</td><td>Negative</td><td>สั่งลบงานเขียนของผู้เข้าร่วมท่านอื่น</td><td>ล็อกอินแต่ไปลบงานของคนอื่น</td><td>ระบบไม่ให้ลบ</td></tr>
            <tr><td>TC-PEN-029</td><td>Avatar Upload</td><td>Negative</td><td>script ใน SVG</td><td>upload svg มี script</td><td>ไม่ execute</td></tr>
            <tr><td>TC-PEN-030</td><td>Network</td><td>Negative</td><td>ใช้เครื่องมือดัก Packet ขณะใส่รหัสผ่าน</td><td>รอใช้ Wireshark จอดักข้อมูลการ Login</td><td>ข้อมูลต้องถูกเข้ารหัส</td></tr>
        </tbody>
    </table>
</body>
</html>
